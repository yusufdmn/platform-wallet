{
  "realm": "platform-wallet",
  "enabled": true,
  "sslRequired": "none",
  "registrationAllowed": false,
  "roles": {
    "realm": [
      {
        "name": "ops-admin",
        "description": "Ops console administrator — grants ledger:admin scope"
      }
    ]
  },
  "users": [
    {
      "username": "ops-admin",
      "enabled": true,
      "realmRoles": ["ops-admin"],
      "credentials": [
        {
          "type": "password",
          "value": "${OPS_ADMIN_PASSWORD}",
          "temporary": false
        }
      ]
    }
  ],
  "clientScopes": [
    {
      "name": "ledger:read",
      "protocol": "openid-connect",
      "attributes": { "include.in.token.scope": "true" }
    },
    {
      "name": "ledger:write",
      "protocol": "openid-connect",
      "attributes": { "include.in.token.scope": "true" }
    },
    {
      "name": "ledger:admin",
      "protocol": "openid-connect",
      "attributes": { "include.in.token.scope": "true" }
    }
  ],
  "clients": [
    {
      "clientId": "ledger-service-client",
      "protocol": "openid-connect",
      "enabled": true,
      "publicClient": false,
      "serviceAccountsEnabled": true,
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "secret": "${KEYCLOAK_CLIENT_SECRET}",
      "defaultClientScopes": [],
      "optionalClientScopes": ["ledger:read", "ledger:write", "ledger:admin"],
      "protocolMappers": [
        {
          "name": "platform-wallet-audience",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.client.audience": "platform-wallet-api",
            "id.token.claim": "false",
            "access.token.claim": "true"
          }
        }
      ]
    },
    {
      "clientId": "ops-console",
      "protocol": "openid-connect",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "attributes": {
        "pkce.code.challenge.method": "S256"
      },
      "redirectUris": [
        "http://localhost:14044/console/callback.html"
      ],
      "webOrigins": ["*"],
      "defaultClientScopes": ["ledger:admin"],
      "optionalClientScopes": [],
      "protocolMappers": [
        {
          "name": "platform-wallet-audience",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.client.audience": "platform-wallet-api",
            "id.token.claim": "false",
            "access.token.claim": "true"
          }
        }
      ]
    }
  ],
  "scopeMappings": [
    {
      "clientScope": "ledger:admin",
      "roles": ["ops-admin"]
    }
  ]
}
