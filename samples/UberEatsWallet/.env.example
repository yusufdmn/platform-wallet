# =============================================================================
# UberEats Wallet sample — environment template
# Copy to samples/UberEatsWallet/.env (git-ignored) and fill in real values.
# This is the sample's OWN env file — it does NOT use the repo-root .env.
# =============================================================================

# ── Where this app listens ──────────────────────────────────────────────────
# launchSettings.json already binds http://localhost:5080 for `dotnet run`.
ASPNETCORE_URLS=http://localhost:5080

# ── Platform Wallet edge (YARP gateway, public data-plane listener) ─────────
# Point at wherever the wallet runs. With the containerized stack on the LAN
# server, that's http://<server-lan-ip>:14041 (see the wallet's GATEWAY_URL).
WALLET_GATEWAY_URL=http://<server-lan-ip>:14041
WALLET_API_VERSION=1
WALLET_ASSET=USD

# ── Auth: Keycloak client_credentials ───────────────────────────────────────
# Token endpoint = {KEYCLOAK_AUTHORITY}/protocol/openid-connect/token.
# Reuse the wallet's service client, or create a dedicated 'ubereats-wallet' client.
WALLET_TOKEN_URL=http://<server-lan-ip>:8088/realms/platform-wallet/protocol/openid-connect/token
WALLET_CLIENT_ID=ledger-service-client
WALLET_CLIENT_SECRET=CHANGE_ME_MATCH_WALLET_KEYCLOAK_CLIENT_SECRET
WALLET_SCOPES=ledger:read ledger:write

# ── Inbound webhooks from the Webhook Dispatcher ────────────────────────────
# MUST equal the wallet's WEBHOOK_HMAC_SECRET. Separately, repoint the wallet's
# WEBHOOK_TARGET_URL at this app's receiver (http://<this-app>:5080/webhooks/wallet)
# and restart the webhook-dispatcher so it delivers here instead of the mock sink.
WEBHOOK_HMAC_SECRET=CHANGE_ME_MUST_MATCH_WALLET_SECRET

# ── This app's own database (SQLite, file-based) ────────────────────────────
ConnectionStrings__AppDb=Data Source=ubereats-wallet.db

# ── Demo data ────────────────────────────────────────────────────────────────
# Opening balance minted to each seeded customer & restaurant wallet (asset USD).
SEED_OPENING_BALANCE=500
