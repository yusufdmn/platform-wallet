@inject UberEatsWallet.Web.Identity.ICurrentActorAccessor Actors
@{
    var actor = Actors.Current;
    var toast = TempData["toast"] as string;
}
<!DOCTYPE html>
<html lang="en" class="h-full">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] · UberEats Wallet</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <script>
        tailwind.config = {
            theme: { extend: { fontFamily: { sans: ['Inter', 'ui-sans-serif', 'system-ui'] } } }
        };
    </script>
    <style>
        body { font-family: 'Inter', ui-sans-serif, system-ui, sans-serif; }
        [x-cloak] { display: none !important; }
    </style>
    <script src="https://unpkg.com/htmx.org@1.9.12" defer></script>
    <script src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js" defer></script>
</head>
<body class="h-full bg-slate-50 text-slate-800">
    <header class="sticky top-0 z-30 border-b border-slate-200 bg-white/90 backdrop-blur">
        <div class="mx-auto flex h-16 max-w-6xl items-center justify-between px-4">
            <a asp-controller="Home" asp-action="Index" class="flex items-center gap-2 text-lg font-bold">
                <span class="grid h-9 w-9 place-items-center rounded-xl bg-emerald-600 text-white">🍔</span>
                <span>UberEats <span class="text-emerald-600">Wallet</span></span>
            </a>
            @if (actor is not null)
            {
                <nav class="hidden items-center gap-1 text-sm font-medium sm:flex">
                    @if (actor.IsCustomer)
                    {
                        <a asp-controller="Restaurants" asp-action="Index" class="rounded-lg px-3 py-2 hover:bg-slate-100">Restaurants</a>
                        <a asp-controller="Orders" asp-action="Index" class="rounded-lg px-3 py-2 hover:bg-slate-100">My Orders</a>
                    }
                    else
                    {
                        <a asp-controller="RestaurantDashboard" asp-action="Index" class="rounded-lg px-3 py-2 hover:bg-slate-100">Dashboard</a>
                    }
                    <a asp-controller="Wallet" asp-action="Index" class="rounded-lg px-3 py-2 hover:bg-slate-100">Wallet</a>
                </nav>
                <div class="flex items-center gap-3">
                    @await Component.InvokeAsync("BalanceChip")
                    <div class="hidden flex-col items-end leading-tight sm:flex">
                        <span class="text-sm font-semibold">@actor.Name</span>
                        <span class="text-xs text-slate-500">@(actor.IsCustomer ? "Customer" : "Restaurant")</span>
                    </div>
                    <form asp-controller="Home" asp-action="Logout" method="post">
                        <button class="rounded-lg border border-slate-200 px-3 py-2 text-sm hover:bg-slate-100">Sign out</button>
                    </form>
                </div>
            }
        </div>
    </header>

    <div x-data="{ show: true }" x-show="show" x-cloak class="border-b border-emerald-100 bg-emerald-50">
        <div class="mx-auto flex max-w-6xl items-center justify-between px-4 py-2 text-sm text-emerald-800">
            <span>Demo integration showcasing the <strong>Platform Wallet</strong> ledger — not a real product.</span>
            <button @@click="show=false" class="text-emerald-700/70 hover:text-emerald-900" aria-label="Dismiss">✕</button>
        </div>
    </div>

    <main class="mx-auto max-w-6xl px-4 py-8">
        @RenderBody()
    </main>

    @if (!string.IsNullOrEmpty(toast))
    {
        <div x-data="{ show: true }" x-show="show" x-cloak x-init="setTimeout(() => show = false, 4500)"
             class="fixed bottom-5 right-5 z-50 flex max-w-sm items-start gap-3 rounded-xl bg-slate-900 px-4 py-3 text-white shadow-lg">
            <span class="text-emerald-400">●</span>
            <span class="text-sm">@toast</span>
        </div>
    }

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
