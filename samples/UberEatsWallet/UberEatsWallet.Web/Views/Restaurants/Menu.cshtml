@model MenuPageViewModel
@{
    ViewData["Title"] = Model.Restaurant.Name;
}

<a asp-controller="Restaurants" asp-action="Index" class="text-sm text-slate-500 hover:text-slate-800">← Restaurants</a>

<div class="mt-2 flex items-center gap-4">
    <span class="grid h-14 w-14 place-items-center rounded-2xl bg-orange-100 text-3xl">🍽️</span>
    <div>
        <h1 class="text-2xl font-bold">@Model.Restaurant.Name</h1>
        <p class="text-slate-500">@Model.Restaurant.Cuisine</p>
    </div>
</div>

<div class="mt-6 space-y-3">
    @foreach (var item in Model.Items)
    {
        <form asp-controller="Restaurants" asp-action="Place" method="post"
              class="flex items-center justify-between gap-4 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm">
            <input type="hidden" name="menuItemId" value="@item.Id" />
            <div>
                <h3 class="font-semibold">@item.Name</h3>
                <p class="text-sm font-medium text-emerald-600">@item.Price.ToString("0.00") USD</p>
            </div>
            <div class="flex items-center gap-2">
                <input name="quantity" type="number" min="1" max="9" value="1"
                       class="w-16 rounded-lg border border-slate-300 px-2 py-2 text-center focus:border-emerald-500 focus:outline-none" />
                <button class="rounded-lg bg-emerald-600 px-4 py-2 font-semibold text-white hover:bg-emerald-700">Order</button>
            </div>
        </form>
    }
</div>
