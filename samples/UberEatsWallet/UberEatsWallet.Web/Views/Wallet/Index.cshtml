@model WalletPageViewModel
@{
    ViewData["Title"] = "Wallet";
}

<div class="grid gap-6 lg:grid-cols-3">
    <div class="rounded-2xl bg-gradient-to-br from-emerald-600 to-emerald-700 p-6 text-white shadow-sm">
        <p class="text-sm text-emerald-100">Available balance</p>
        @if (Model.Balance is not null)
        {
            <p class="mt-1 text-4xl font-bold">
                @Model.Balance.Balance.ToString("0.00") <span class="text-lg font-medium text-emerald-100">@Model.Balance.Asset</span>
            </p>
            @if (Model.Balance.HeldAmount > 0)
            {
                <p class="mt-2 text-sm text-emerald-100">@Model.Balance.HeldAmount.ToString("0.00") held in pending orders</p>
            }
        }
        else
        {
            <p class="mt-1 text-2xl font-semibold">No account yet</p>
            <p class="mt-2 text-sm text-emerald-100">Top up to create your wallet.</p>
        }
    </div>

    <div class="grid gap-4 sm:grid-cols-2 lg:col-span-2">
        <form asp-controller="Wallet" asp-action="TopUp" method="post" class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
            <h3 class="font-semibold">Top up</h3>
            <p class="mt-1 text-xs text-slate-500">Mock card → mints to your wallet.</p>
            <div class="mt-3 flex gap-2">
                <input name="amount" type="number" step="0.01" min="0.01" value="50" class="w-full rounded-lg border border-slate-300 px-3 py-2 focus:border-emerald-500 focus:outline-none" />
                <button class="rounded-lg bg-emerald-600 px-4 py-2 font-semibold text-white hover:bg-emerald-700">Add</button>
            </div>
        </form>
        <form asp-controller="Wallet" asp-action="Withdraw" method="post" class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
            <h3 class="font-semibold">Withdraw</h3>
            <p class="mt-1 text-xs text-slate-500">Burns from your wallet → bank.</p>
            <div class="mt-3 flex gap-2">
                <input name="amount" type="number" step="0.01" min="0.01" value="20" class="w-full rounded-lg border border-slate-300 px-3 py-2 focus:border-emerald-500 focus:outline-none" />
                <button class="rounded-lg border border-slate-300 px-4 py-2 font-semibold hover:bg-slate-100">Cash out</button>
            </div>
        </form>
    </div>
</div>

<div class="mt-6 overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-sm">
    <div class="border-b border-slate-100 px-5 py-4"><h3 class="font-semibold">Ledger history</h3></div>
    @if (Model.History.Items.Count == 0)
    {
        <p class="px-5 py-8 text-center text-sm text-slate-500">No postings yet.</p>
    }
    else
    {
        <table class="w-full text-sm">
            <thead class="text-left text-xs uppercase tracking-wide text-slate-500">
                <tr>
                    <th class="px-5 py-3">When</th>
                    <th class="px-5 py-3">Phase</th>
                    <th class="px-5 py-3">Kind</th>
                    <th class="px-5 py-3 text-right">Amount</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-slate-100">
                @foreach (var entry in Model.History.Items)
                {
                    <tr>
                        <td class="px-5 py-3 text-slate-500">@entry.CreatedAt.LocalDateTime.ToString("MMM d, HH:mm")</td>
                        <td class="px-5 py-3">@entry.Phase</td>
                        <td class="px-5 py-3">@entry.EntryKind</td>
                        <td class="px-5 py-3 text-right font-medium @(entry.AmountSigned < 0 ? "text-rose-600" : "text-emerald-600")">@entry.AmountSigned.ToString("+0.00;-0.00")</td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>
