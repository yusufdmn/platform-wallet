{
  "Logging": { "LogLevel": { "Default": "Information", "Yarp": "Information" } },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "intake-mint": {
        "ClusterId": "intake",
        "AuthorizationPolicy": "LedgerWrite",
        "Match": {
          "Path": "/mint",
          "Methods": [ "POST" ],
          "Headers": [{ "Name": "api-version", "Values": [ "1" ], "Mode": "ExactHeader" }]
        }
      },
      "intake-burn": {
        "ClusterId": "intake",
        "AuthorizationPolicy": "LedgerWrite",
        "Match": {
          "Path": "/burn",
          "Methods": [ "POST" ],
          "Headers": [{ "Name": "api-version", "Values": [ "1" ], "Mode": "ExactHeader" }]
        }
      },
      "intake-transfer": {
        "ClusterId": "intake",
        "AuthorizationPolicy": "LedgerWrite",
        "Match": {
          "Path": "/transfer/{**catch-all}",
          "Methods": [ "POST" ],
          "Headers": [{ "Name": "api-version", "Values": [ "1" ], "Mode": "ExactHeader" }]
        }
      },
      "intake-read": {
        "ClusterId": "intake",
        "AuthorizationPolicy": "LedgerRead",
        "Match": {
          "Path": "/transactions/{id}",
          "Methods": [ "GET" ],
          "Headers": [{ "Name": "api-version", "Values": [ "1" ], "Mode": "ExactHeader" }]
        }
      },
      "balance-read": {
        "ClusterId": "balance",
        "AuthorizationPolicy": "LedgerRead",
        "Match": {
          "Path": "/accounts/{**catch-all}",
          "Methods": [ "GET" ],
          "Headers": [{ "Name": "api-version", "Values": [ "1" ], "Mode": "ExactHeader" }]
        }
      },
      "admin-invariants": {
        "ClusterId": "ledger-admin",
        "AuthorizationPolicy": "LedgerAdmin",
        "Match": { "Path": "/admin/invariants/{**catch-all}" }
      },
      "admin-transactions": {
        "ClusterId": "intake",
        "AuthorizationPolicy": "LedgerAdmin",
        "Match": { "Path": "/admin/transactions/{**catch-all}" }
      },
      "admin-sagas": {
        "ClusterId": "saga-admin",
        "AuthorizationPolicy": "LedgerAdmin",
        "Match": { "Path": "/admin/sagas/{**catch-all}" }
      },
      "admin-webhooks": {
        "ClusterId": "webhook-admin",
        "AuthorizationPolicy": "LedgerAdmin",
        "Match": { "Path": "/admin/webhooks/{**catch-all}" }
      },
      "admin": {
        "ClusterId": "saga-admin",
        "AuthorizationPolicy": "LedgerAdmin",
        "Match": { "Path": "/admin/{**catch-all}" }
      }
    },
    "Clusters": {
      "intake":        { "Destinations": { "d1": { "Address": "http://transaction-intake:8080/" } } },
      "balance":       { "Destinations": { "d1": { "Address": "http://balance-query:8080/" } } },
      "ledger-admin":  { "Destinations": { "d1": { "Address": "http://ledger:8080/" } } },
      "saga-admin":    { "Destinations": { "d1": { "Address": "http://saga-orchestrator:8080/" } } },
      "webhook-admin": { "Destinations": { "d1": { "Address": "http://webhook-dispatcher:8080/" } } }
    }
  }
}
