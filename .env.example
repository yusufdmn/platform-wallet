# =============================================================================
# Platform Wallet — environment variables template
# Copy this file to .env (git-ignored) and fill in real values.
#
# TOPOLOGY:
#   Infrastructure (Postgres, RabbitMQ, Redis, Keycloak, OTel…) runs on the
#   LAN server via deploy/docker-compose.infra.yml.
#   Set all ← INFRA_HOST values to that server's LAN IP.
#
# TO CHANGE THE SERVER IP: update INFRA_HOST comment and all ← INFRA_HOST vars.
# REDIS_CONNECTION must also be updated manually (it is a composite string).
# =============================================================================

# Master LAN-server IP — update this comment and all ← INFRA_HOST vars together
INFRA_HOST=<server-lan-ip>

# ── Postgres ──────────────────────────────────────────────────────────────────
# POSTGRES_USER / POSTGRES_PASSWORD are used for two things:
#   1. docker-compose.infra.yml — sets the superuser on the Postgres container.
#   2. All .NET services — connect to their per-service DB as the `wallet` role
#      using these same credentials.
POSTGRES_HOST=<server-lan-ip>        # ← INFRA_HOST
POSTGRES_PORT=5432
POSTGRES_USER=CHANGE_ME
POSTGRES_PASSWORD=CHANGE_ME

# ── RabbitMQ ──────────────────────────────────────────────────────────────────
# docker-compose maps RABBITMQ_DEFAULT_PASSWORD → RABBITMQ_DEFAULT_PASS inside
# the container. Services read RABBITMQ_DEFAULT_PASSWORD directly.
RABBITMQ_HOST=<server-lan-ip>        # ← INFRA_HOST
RABBITMQ_PORT=5672
RABBITMQ_DEFAULT_USER=CHANGE_ME
RABBITMQ_DEFAULT_PASSWORD=CHANGE_ME
# Management API used by the Ops Console DLQ Replayer
RABBITMQ_MGMT_URL=http://<server-lan-ip>:15672
RABBITMQ_VHOST=/

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=<server-lan-ip>           # ← INFRA_HOST
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME
# Composite connection string consumed by BalanceQuery and ApiGateway.
# Must be kept in sync with REDIS_HOST:REDIS_PORT,password=REDIS_PASSWORD.
# Docker Compose cannot interpolate variables inside .env, so this is explicit.
REDIS_CONNECTION=<server-lan-ip>:6379,password=CHANGE_ME

# ── Keycloak ──────────────────────────────────────────────────────────────────
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=CHANGE_ME
# Password for the ops-admin Keycloak user (logs into the Ops Console via PKCE)
OPS_ADMIN_PASSWORD=CHANGE_ME
# MUST match the URL clients use to reach Keycloak.
# Keycloak (start-dev) derives the token `iss` claim from the incoming request
# URL. If this differs from how clients access Keycloak, every service will
# reject tokens with 401.
KEYCLOAK_AUTHORITY=http://<server-lan-ip>:8088/realms/platform-wallet   # ← INFRA_HOST
# Must match the `secret` field in deploy/keycloak/realm-export.json
KEYCLOAK_CLIENT_SECRET=ledger-service-secret

# ── Observability ─────────────────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://<server-lan-ip>:4317   # ← INFRA_HOST
SEQ_URL=http://<server-lan-ip>:5341                        # ← INFRA_HOST
GRAFANA_ADMIN_PASSWORD=CHANGE_ME

# ── Balance Query → Ledger gRPC ───────────────────────────────────────────────
# Ledger exposes HTTP/1.1 on 8080 (REST/healthcheck) and HTTP/2 on 9090 (gRPC).
# docker-compose.yml overrides this to http://ledger:9090 (Docker service name).
LEDGER_GRPC_URL=http://localhost:9090

# ── API Gateway — YARP cluster overrides for local dotnet run ─────────────────
# Ports match each service's launchSettings.json HTTP URL.
# docker-compose.yml overrides these to Docker container service names.
ReverseProxy__Clusters__intake__Destinations__d1__Address=http://localhost:14040/
ReverseProxy__Clusters__balance__Destinations__d1__Address=http://localhost:14039/
ReverseProxy__Clusters__ledger-admin__Destinations__d1__Address=http://localhost:14038/
ReverseProxy__Clusters__saga-admin__Destinations__d1__Address=http://localhost:14042/
ReverseProxy__Clusters__webhook-admin__Destinations__d1__Address=http://localhost:14043/

# ── Webhook Dispatcher ────────────────────────────────────────────────────────
# Any 32+ byte random string — HMAC-SHA256 signing key for X-Signature header.
WEBHOOK_HMAC_SECRET=CHANGE_ME_USE_AT_LEAST_32_RANDOM_BYTES
# Dev: point to the local webhook-sink.
# docker-compose.yml overrides this to http://webhook-sink:8080/webhook.
WEBHOOK_TARGET_URL=http://localhost:9999/webhook

# ── E2E Tests ─────────────────────────────────────────────────────────────────
E2E_BASE_URL=http://localhost:14041
E2E_KEYCLOAK_URL=http://<server-lan-ip>:8088   # ← INFRA_HOST
