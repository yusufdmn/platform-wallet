# =============================================================================
# Platform Wallet — Local Environment Template
# =============================================================================
# Copy this file to `.env` at the repo root and fill in real values. A single
# `.env` at the repo root is the only env file in this repo — do not create
# `deploy/.env` or per-folder copies. Docker Compose is invoked from the repo
# root so it picks this file up automatically. `.env` is git-ignored.
#
# HUMAN ACTION REQUIRED: see /CLAUDE.md §9 for the full list of human-only
# setup steps. None of these values are written by the agent.
# =============================================================================

# ---- Postgres -----------------------------------------------------------
POSTGRES_USER=wallet
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=postgres
POSTGRES_PORT=5432

# ---- RabbitMQ -----------------------------------------------------------
RABBITMQ_DEFAULT_USER=wallet
RABBITMQ_DEFAULT_PASS=CHANGE_ME
RABBITMQ_PORT=5672
RABBITMQ_MGMT_PORT=15672

# ---- Redis --------------------------------------------------------------
REDIS_PORT=6379

# ---- Keycloak -----------------------------------------------------------
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=CHANGE_ME
KEYCLOAK_PORT=8088
# Secret for the `ledger-service-client` confidential client in realm-export.json.
# MUST MATCH the `secret` value in deploy/keycloak/realm-export.json.
KEYCLOAK_CLIENT_SECRET=CHANGE_ME

# ---- Webhook signing ----------------------------------------------------
# Any 32+ byte random string. Used as the HMAC key for X-Signature.
WEBHOOK_HMAC_SECRET=CHANGE_ME_AT_LEAST_32_BYTES_OF_ENTROPY

# ---- Webhook target (the "host backend" callback URL) ------------------
WEBHOOK_TARGET_URL=http://webhook-sink:1025/hook

# ---- Observability ------------------------------------------------------
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
SEQ_API_KEY=
SEQ_PORT=5341
JAEGER_PORT=16686
PROMETHEUS_PORT=9090
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_ME
GRAFANA_PORT=3000

# ---- Gateway ------------------------------------------------------------
GATEWAY_PORT=8080

# ---- GitHub (for the GitHub MCP server — belongs in your user scope
# ~/.claude/.env or shell env, NOT in this repo-root .env)
# GH_PAT=ghp_xxxx
