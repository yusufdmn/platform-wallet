# =============================================================================
# Platform Wallet — environment variables
# Copy this file to .env (git-ignored) and fill in real values.
#
# TOPOLOGY: During development, infrastructure runs on a LAN server via
# docker-compose.infra.yml. Set all HOST values to the server's LAN IP.
# In the final containerized deployment replace IPs with Docker service names.
# =============================================================================

# ── Postgres ──────────────────────────────────────────────────────────────────
POSTGRES_HOST=<server-lan-ip>
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME

# ── RabbitMQ ──────────────────────────────────────────────────────────────────
RABBITMQ_HOST=<server-lan-ip>
RABBITMQ_PORT=5672
RABBITMQ_DEFAULT_USER=rabbit
RABBITMQ_DEFAULT_PASSWORD=CHANGE_ME

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=<server-lan-ip>
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME

# ── Keycloak ──────────────────────────────────────────────────────────────────
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=CHANGE_ME
# Full realm URL. MUST match the URL clients use to reach Keycloak — Keycloak
# (in start-dev mode) derives the token `iss` claim from the incoming request
# URL. If KEYCLOAK_AUTHORITY differs from how clients access Keycloak, every
# service will reject tokens with 401.
# Dev:   http://<server-lan-ip>:8088/realms/platform-wallet
# Final: http://keycloak:8080/realms/platform-wallet
KEYCLOAK_AUTHORITY=http://<server-lan-ip>:8088/realms/platform-wallet
# Must match the `secret` field in deploy/keycloak/realm-export.json
KEYCLOAK_CLIENT_SECRET=ledger-service-secret

# ── OTel Collector ────────────────────────────────────────────────────────────
# Dev:   http://<server-lan-ip>:4317
# Final: http://otel-collector:4317
OTEL_EXPORTER_OTLP_ENDPOINT=http://<server-lan-ip>:4317

# Serilog → Seq direct log sink
# Dev:   http://<server-lan-ip>:5341
# Final: http://seq:5341
SEQ_URL=http://<server-lan-ip>:5341

# ── Grafana ───────────────────────────────────────────────────────────────────
GRAFANA_ADMIN_PASSWORD=CHANGE_ME

# ── Webhook Dispatcher ────────────────────────────────────────────────────────
# Any 32+ byte random string used as the HMAC-SHA256 key for X-Signature.
WEBHOOK_HMAC_SECRET=CHANGE_ME_AT_LEAST_32_BYTES
# URL the Webhook Dispatcher POSTs signed events to.
WEBHOOK_TARGET_URL=http://webhook-sink:1025/hook
