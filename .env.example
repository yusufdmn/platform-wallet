# =============================================================================
# Platform Wallet — environment variables
# Copy this file to .env (git-ignored) and fill in real values.
#
# TOPOLOGY: Infrastructure (Postgres, RabbitMQ, Redis, Keycloak, OTel, Seq)
# runs on a LAN server via deploy/docker-compose.infra.yml.
# .NET services run locally with `dotnet run`.
# Replace <server-lan-ip> with your server's actual LAN IP (e.g. 192.168.1.10).
# =============================================================================

# ── Postgres ──────────────────────────────────────────────────────────────────
# POSTGRES_USER / POSTGRES_PASSWORD are used for TWO things:
#   1. docker-compose.infra.yml — sets the superuser on the Postgres container.
#   2. All .NET services — connect to their per-service DB as the `wallet` role
#      using these same credentials.
# The init-databases.sql script reads POSTGRES_PASSWORD via \getenv to set the
# wallet role password, so they always stay in sync.
POSTGRES_HOST=<server-lan-ip>
POSTGRES_PORT=5432
POSTGRES_USER=wallet
POSTGRES_PASSWORD=CHANGE_ME

# ── RabbitMQ ──────────────────────────────────────────────────────────────────
# docker-compose maps RABBITMQ_DEFAULT_PASSWORD → RABBITMQ_DEFAULT_PASS inside
# the container. Services read RABBITMQ_DEFAULT_PASSWORD directly.
RABBITMQ_HOST=<server-lan-ip>
RABBITMQ_PORT=5672
RABBITMQ_DEFAULT_USER=wallet
RABBITMQ_DEFAULT_PASSWORD=CHANGE_ME

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=<server-lan-ip>
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME
# Composite connection string consumed by BalanceQuery and ApiGateway.
REDIS_CONNECTION=<server-lan-ip>:6379,password=CHANGE_ME

# ── Keycloak ──────────────────────────────────────────────────────────────────
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=CHANGE_ME
# Full realm URL — MUST match the URL clients use to reach Keycloak.
# Keycloak (start-dev) derives the `iss` claim from the incoming request URL.
# If KEYCLOAK_AUTHORITY mismatches the URL in any request, every service
# rejects tokens with 401.
KEYCLOAK_AUTHORITY=http://<server-lan-ip>:8088/realms/platform-wallet
# Must match the `secret` field in deploy/keycloak/realm-export.json.
# The realm-export.json ships with: ledger-service-secret
KEYCLOAK_CLIENT_SECRET=ledger-service-secret

# ── OTel Collector ────────────────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://<server-lan-ip>:4317

# ── Seq (structured logs) ─────────────────────────────────────────────────────
SEQ_URL=http://<server-lan-ip>:5341

# ── Grafana ───────────────────────────────────────────────────────────────────
GRAFANA_ADMIN_PASSWORD=CHANGE_ME

# ── Balance Query → Ledger gRPC ───────────────────────────────────────────────
# HTTP port from Ledger.Api launchSettings.json (Kestrel hosts HTTP + gRPC together).
# Check src/Ledger/Ledger.Api/Properties/launchSettings.json for the actual port.
LEDGER_GRPC_URL=http://localhost:<ledger-http-port>

# ── API Gateway (YARP) — local dev cluster overrides ─────────────────────────
# Without these, the gateway tries Docker service names that don't resolve locally.
# Use the http (not https) applicationUrl port from each service's launchSettings.json.
# SagaOrchestrator is a Worker (no HTTP) — point saga-admin at ledger or omit.
ReverseProxy__Clusters__intake__Destinations__d1__Address=http://localhost:<intake-port>/
ReverseProxy__Clusters__balance__Destinations__d1__Address=http://localhost:<balance-port>/
ReverseProxy__Clusters__ledger-admin__Destinations__d1__Address=http://localhost:<ledger-port>/
ReverseProxy__Clusters__saga-admin__Destinations__d1__Address=http://localhost:<ledger-port>/

# ── Webhook Dispatcher ────────────────────────────────────────────────────────
# Any 32+ byte random string — used as the HMAC-SHA256 signing key.
WEBHOOK_HMAC_SECRET=CHANGE_ME_AT_LEAST_32_BYTES
# URL the Webhook Dispatcher POSTs signed events to (your "host backend" receiver).
# During local dev, point this to the webhook-sink or any HTTP listener.
WEBHOOK_TARGET_URL=http://localhost:9999/webhook
